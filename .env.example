# ── PUSPA App Environment Variables ──
# Copy this file to .env.local for local development
# For Vercel deployment, set these in Vercel Dashboard > Settings > Environment Variables

# Database (Turso / libSQL)
# Local dev: file:db/custom.db
# Vercel/Turso: libsql://your-db-name-your-org.turso.io?authToken=your-jwt-token
DATABASE_URL=file:db/custom.db

# AI SDK (z-ai-web-dev-sdk) - required for AI Chat and AI Reports
# If not set, AI features will return fallback responses
# Check SDK documentation for available environment variables
