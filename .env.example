# ── PUSPA App Environment Variables ──
# Copy this file to .env.local for local development
# For Vercel deployment, set these in Vercel Dashboard > Settings > Environment Variables

# ═══════════════════════════════════════════════════════════
# DATABASE (Supabase PostgreSQL) — REQUIRED
# ═══════════════════════════════════════════════════════════
# Get these from: Supabase Dashboard > Project Settings > Database > Connection string > URI
#
# For Vercel (Connection Pooler - recommended):
DATABASE_URL="postgresql://postgres.fahywepalxxyhnyetptq:[YOUR-DB-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# For direct connection (migrations/seeding locally):
DIRECT_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.fahywepalxxyhnyetptq.supabase.co:5432/postgres"
#
# HOW TO GET YOUR DB PASSWORD:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project (fahywepalxxyhnyetptq)
# 3. Go to Settings > Database
# 4. Scroll to "Connection string" section
# 5. Select "URI" tab
# 6. Copy the full connection string
# 7. Replace [YOUR-DB-PASSWORD] with your actual password
#    (The password is the one you set when creating the project,
#     or use "Reset database password" if you forgot it)

# ═══════════════════════════════════════════════════════════
# SUPABASE (Optional — for client-side features)
# ═══════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://fahywepalxxyhnyetptq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Session + setup security
TOKEN_SECRET=replace-with-a-long-random-secret-at-least-24-chars
SETUP_SECRET=replace-with-a-long-random-setup-secret

# Demo/setup routes are disabled by default for safety
PUSPA_ENABLE_DEMO_SEEDING=false
PUSPA_ENABLE_SETUP_ROUTE=false

# OpenClaw webhook bridge (optional)
# Example URL: https://operator.gangniaga.my/plugins/webhooks/puspa
# Recommended: use OpenClaw to fan out PUSPA events to a dedicated Telegram bot account such as PuspaCareBot.
PUSPA_OPENCLAW_WEBHOOK_ENABLED=false
PUSPA_OPENCLAW_WEBHOOK_URL=
PUSPA_OPENCLAW_WEBHOOK_SECRET=

# Direct Telegram notifications (optional)
# Use when you want PUSPA to send concise ops alerts straight to Telegram.
PUSPA_TELEGRAM_ENABLED=false
PUSPA_TELEGRAM_BOT_TOKEN=
PUSPA_TELEGRAM_CHAT_ID=
