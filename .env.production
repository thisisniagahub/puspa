# Production values belong in your deployment platform secret manager, not in git.
DATABASE_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.example.supabase.co:5432/postgres?sslmode=require&connect_timeout=15"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
TOKEN_SECRET="replace-with-a-long-random-secret-at-least-24-chars"
SETUP_SECRET="replace-with-a-long-random-setup-secret"
PUSPA_ENABLE_DEMO_SEEDING="false"
PUSPA_ENABLE_SETUP_ROUTE="false"
